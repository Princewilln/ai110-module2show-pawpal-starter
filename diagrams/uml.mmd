classDiagram
    class Owner {
        +String name
        +List~Pet~ pets
        +addPet(pet Pet) void
        +removePet(petId String) void
        +getDailySchedule() List~Task~
    }

    class Pet {
        +String id
        +String name
        +String species
        +int age
        +List~Task~ tasks
        +addTask(task Task) void
        +removeTask(taskId String) void
    }

    class Scheduler {
        +List~Task~ tasks
        +addTask(task Task) void
        +removeTask(taskId String) void
        +getSortedTasks() List~Task~
        +detectConflict(task Task) bool
        +generateDailyPlan() List~Task~
    }

    class Task {
        +String id
        +String type
        +datetime scheduledTime
        +bool recurring
        +String frequency
        +bool completed
        +markComplete() void
    }

    Owner "1" --> "0..*" Pet : owns
    Owner "1" --> "1" Scheduler : uses
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "0..*" Task : manages
