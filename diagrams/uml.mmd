classDiagram
    class Owner {
        +String name
        +List~Pet~ pets
        +Scheduler scheduler
        +addPet(pet Pet) void
        +removePet(petId String) void
        +getDailySchedule(date datetime) List~Task~
    }

    class Pet {
        +String id
        +String name
        +String species
        +int age
        +List~Task~ tasks
        +addTask(task Task) void
        +removeTask(taskId String) void
    }

    class Scheduler {
        +List~Pet~ pets
        +addTask(task Task) void
        +removeTask(taskId String) void
        +getSortedTasks() List~Task~
        +detectConflict(task Task) Optional~Task~
        +generateDailyPlan(date datetime) List~Task~
    }

    class Task {
        +String id
        +String petId
        +String taskType
        +datetime scheduledTime
        +bool recurring
        +String frequency
        +bool completed
        +markComplete() void
    }

    Owner "1" *-- "1" Scheduler : owns
    Owner "1" --> "0..*" Pet : owns
    Scheduler "1" --> "0..*" Pet : aggregates
    Pet "1" --> "0..*" Task : has
    Task "0..*" ..> "1" Pet : petId ref
